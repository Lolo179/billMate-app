{
  "info": {
    "_postman_id": "2cad273e-0221-4541-add8-386a757e030f",
    "name": "BillMate - Clientes E2E",
    "description": "Batería completa para cliente: creación, modificación, obtención, eliminación",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "33031976"
  },
  "item": [
    {
      "name": "🔐 Login (Admin)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.environment.set(\"TOKEN\", json.token);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{ \"email\": \"admin@mail.com\", \"password\": \"admin123\" }"
        },
        "url": {
          "raw": "{{BASE_URL}}/auth/login",
          "host": [
            "{{BASE_URL}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "📥 Crear cliente y guardar ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.environment.set(\"CLIENT_ID\", json.clientId);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{TOKEN}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Luis Cliente\",\n  \"email\": \"luis@mail.com\",\n  \"nif\": \"87654321T\",\n  \"address\": \"Calle Cliente 321\"\n}"
        },
        "url": {
          "raw": "{{BASE_URL}}/billing/clients",
          "host": [
            "{{BASE_URL}}"
          ],
          "path": [
            "billing",
            "clients"
          ]
        }
      },
      "response": []
    },
