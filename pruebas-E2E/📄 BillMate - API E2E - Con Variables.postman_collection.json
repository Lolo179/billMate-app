    {
      "name": "🔐 Auth",
      "description": "Login para obtener token JWT",
      "item": [
        {
          "name": "🔐 Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login successful - status 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.environment.set('TOKEN', json.token);",
                  "pm.test('Token saved', () => {",
                  "    pm.expect(json.token).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{ \"email\": \"admin@mail.com\", \"password\": \"admin123\" }"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/login",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "response": []
        }
      ]
    },
