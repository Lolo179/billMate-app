    {
      "name": "🧾 Facturas",
      "description": "Flujo completo: crear, consultar, modificar, emitir, pagar, PDF, eliminar",
      "item": [
        {
          "name": "✅ Crear factura válida",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Invoice created - status 201', () => {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.environment.set('invoiceId', json.invoiceId);",
                  "pm.test('invoiceId saved', () => {",
                  "    pm.expect(json.invoiceId).to.be.a('number');",
                  "});",
                  "pm.test('Status is DRAFT', () => {",
                  "    pm.expect(json.status).to.eql('DRAFT');",
                  "});",
                  "pm.test('Total includes 21% tax', () => {",
                  "    pm.expect(json.total).to.eql(363.00);",
                  "});",
                  "pm.test('Line total is populated', () => {",
                  "    pm.expect(json.invoiceLines[0].total).to.eql(300.0);",
                  "});"
                ]
              }
            }
          ],
