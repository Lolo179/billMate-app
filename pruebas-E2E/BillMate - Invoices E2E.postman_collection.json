    {
      "name": "📑 Flujo Facturas",
      "description": "Flujo completo: crear, modificar, emitir, pagar, descargar, consultar y eliminar",
      "item": [
        {
          "name": "✅ Crear factura (DRAFT) y guardar ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Invoice created - status 201', () => {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.environment.set('INVOICE_ID', json.invoiceId);",
                  "pm.test('INVOICE_ID saved', () => {",
                  "    pm.expect(json.invoiceId).to.be.a('number');",
                  "});",
                  "pm.test('Status is DRAFT', () => {",
                  "    pm.expect(json.status).to.eql('DRAFT');",
                  "});",
                  "pm.test('Total includes tax (21%)', () => {",
                  "    pm.expect(json.total).to.eql(484.00);",
                  "});",
                  "pm.test('Invoice lines have total', () => {",
                  "    pm.expect(json.invoiceLines[0].total).to.eql(400.0);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientId\": {{CLIENT_ID}},\n  \"date\": \"2025-06-01\",\n  \"status\": \"DRAFT\",\n  \"description\": \"Factura Junio\",\n  \"invoiceLines\": [\n    {\n      \"description\": \"Servicio técnico\",\n      \"quantity\": 2,\n      \"unitPrice\": 200\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/billing/invoices",
              "host": ["{{BASE_URL}}"],
              "path": ["billing", "invoices"]
            }
          },
          "response": []
        },
        {
          "name": "✏️ Modificar factura",
          "event": [
            {
              "listen": "test",
              "script": {
