          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Cliente E2E Test\",\n  \"email\": \"e2etest@mail.com\",\n  \"nif\": \"99999999R\",\n  \"address\": \"Calle Test 123, Madrid\",\n  \"phone\": \"+34 600 999 999\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/billing/clients",
              "host": ["{{BASE_URL}}"],
              "path": ["billing", "clients"]
