  "item": [
    {
      "name": "🔐 Setup",
      "description": "Pasos de preparación: registro, login y creación de cliente",
      "item": [
        {
          "name": "🔑 Registrar usuario de prueba",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.environment.set('TOKEN', json.token);",
                  "    pm.test('User registered and token saved', () => {",
                  "        pm.expect(json.token).to.be.a('string').and.not.empty;",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"testuser@billmate.com\",\n  \"password\": \"Test1234!\",\n  \"role\": \"USER\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/register",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "register"]
            }
          },
          "response": []
        },
        {
          "name": "🔓 Login y guardar TOKEN",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login successful - status 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.environment.set('TOKEN', json.token);",
                  "pm.test('Token saved', () => {",
                  "    pm.expect(json.token).to.be.a('string').and.not.empty;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@billmate.com\",\n  \"password\": \"Test1234!\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/login",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "login"]
            }
          },
          "response": []
        },
