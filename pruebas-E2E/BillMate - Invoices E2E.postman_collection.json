          "name": "👤 Crear cliente de prueba y guardar CLIENT_ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Client created - status 201', () => {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.environment.set('CLIENT_ID', json.clientId);",
                  "pm.test('CLIENT_ID saved', () => {",
