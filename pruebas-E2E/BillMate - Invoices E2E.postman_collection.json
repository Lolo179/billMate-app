                  "const json = pm.response.json();",
                  "pm.test('Description updated', () => {",
                  "    pm.expect(json.description).to.eql('Factura modificada');",
                  "});",
                  "pm.test('Total recalculated with tax', () => {",
                  "    pm.expect(json.total).to.eql(653.40);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              },
              {
                "key": "Content-Type",
