            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientId\": {{CLIENT_ID}},\n  \"date\": \"2025-06-01\",\n  \"status\": \"DRAFT\",\n  \"description\": \"Factura modificada\",\n  \"invoiceLines\": [\n    {\n      \"description\": \"Servicio modificado\",\n      \"quantity\": 3,\n      \"unitPrice\": 180\n    }\n  ]\n}"
            },
